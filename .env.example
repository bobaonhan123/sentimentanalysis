# ── Postgres ──────────────────────────────────────
POSTGRES_USER=review
POSTGRES_PASSWORD=changeme
POSTGRES_DB=review_company
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://review:changeme@localhost:5432/review_company

# ── Crawler ──────────────────────────────────────
CRAWL_DELAY=1.5
CRAWL_MAX_PAGES=250
CRAWL_CONCURRENCY=3
BLOOM_CAPACITY=500000
BLOOM_ERROR_RATE=0.001

# ── Cookies (paste from browser if needed) ───────
SESSION_COOKIE=

# ── Airflow (only needed inside airflow container) 
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql://review:changeme@postgres:5432/review_company
