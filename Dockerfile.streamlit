FROM python:3.11-slim
WORKDIR /app
COPY pyproject.toml .
RUN pip install --no-cache-dir uv && \
    uv pip install --system streamlit pandas sqlalchemy psycopg2-binary pydantic pydantic-settings
COPY src/ src/
EXPOSE 8501
CMD ["streamlit", "run", "src/export/app.py", "--server.address=0.0.0.0", "--server.port=8501"]
